# Which LLM proxy the browser calls: nvidia (default) or azure (ZotGPT / Azure OpenAI).
# Must be prefixed with VITE_ so the client bundle can read it — rebuild after change.
VITE_LLM_PROVIDER=nvidia

# NVIDIA API (OpenAI-compatible chat-completions) — used when VITE_LLM_PROVIDER=nvidia
# Consumed by src/server/nvidia-middleware.ts (server-side only).
NVIDIA_API_KEY=
# Optional — override the model id. Defaults to meta/llama-3.1-70b-instruct.
NVIDIA_MODEL=

# Azure OpenAI–compatible API (e.g. UCI ZotGPT) — used when VITE_LLM_PROVIDER=azure
# Request URL: {AZURE_OPENAI_ENDPOINT}/deployments/{AZURE_OPENAI_DEPLOYMENT}/chat/completions?api-version=...
AZURE_OPENAI_ENDPOINT=https://azureapi.zotgpt.uci.edu/openai
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_KEY=
# Azure REST api-version query param (see your ZotGPT / Azure docs).
AZURE_OPENAI_API_VERSION=2024-06-01
# Optional: use "bearer" if your gateway expects Authorization: Bearer instead of api-key.
# AZURE_OPENAI_AUTH_MODE=api-key

# Spotify app credentials (Client Credentials flow).
# Consumed by src/domains/playlist/spotifyCredentials.ts → setSpotifyToken.
# NOTE: When exposed to the browser via Vite, the secret is bundled into
# client JS. Only use throwaway/development credentials here.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# YouTube Data API v3 (adapter currently stubbed — value is unused until
# src/domains/playlist/adapters/youtube.ts is implemented).
YOUTUBE_API_KEY=
