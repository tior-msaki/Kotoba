# NVIDIA API (OpenAI-compatible chat-completions)
# Consumed by src/lib/nvidia.ts via setup.setNvidiaApiKey (services/app.ts).
NVIDIA_API_KEY=
# Optional — override the model id. Defaults to meta/llama-3.1-70b-instruct.
NVIDIA_MODEL=

# Spotify app credentials (Client Credentials flow).
# Consumed by src/domains/playlist/spotifyCredentials.ts → setSpotifyToken.
# NOTE: When exposed to the browser via Vite, the secret is bundled into
# client JS. Only use throwaway/development credentials here.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# YouTube Data API v3 (adapter currently stubbed — value is unused until
# src/domains/playlist/adapters/youtube.ts is implemented).
YOUTUBE_API_KEY=
